# URL de conexão do MongoDB (deixe em branco para usar o localStorage do navegador por padrão)
MONGODB_URI=mongodb+srv://<usuario>:<senha>@cluster0.xxxx.mongodb.net/kuhula?retryWrites=true&w=majority

# Chave de API do Google Gemini (necessária para habilitar o chat inteligente e comandos da IA)
GEMINI_API_KEY=sua_chave_api_aqui
