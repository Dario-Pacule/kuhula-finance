# ── Supabase ────────────────────────────────────────────────
# Obtém em: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ── IA (opcional — o utilizador pode configurar na app) ─────
# Gemini (Google AI Studio — https://aistudio.google.com)
GEMINI_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Groq (https://console.groq.com)
GROQ_API_KEY=

# ── MongoDB (DEPRECIADO — migrado para Supabase) ────────────
# Manter apenas se ainda tiveres dados a migrar.
# MONGODB_URI=mongodb+srv://...

# URL pública da app (para email de confirmação)
NEXT_PUBLIC_APP_URL=https://kuhula-finance.vercel.app

# ── Migrations (necessário para correr migrations automáticas) ─
# Supabase Dashboard → Settings → Database → Connection string (Direct)
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[db-password]@aws-0-eu-west-2.pooler.supabase.com:5432/postgres
# Alternativa: só a password (o URL é construído automaticamente)
SUPABASE_DB_PASSWORD=your-database-password
